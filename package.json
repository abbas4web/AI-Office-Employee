{
  "name": "express-postgres-backend",
  "version": "1.0.0",
  "description": "Node.js Express backend with PostgreSQL",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "migrate": "node src/db/migrate.js",
    "add-column": "node src/db/add_password_column.js",
    "seed": "node src/db/seed.js",
    "setup": "npm run migrate && npm run seed",
    "setup-fresh": "npm run add-column && npm run seed"
  },
  "dependencies": {
    "bcryptjs": "2.4.3",
    "cors": "2.8.5",
    "dotenv": "16.4.5",
    "express": "4.19.2",
    "groq-sdk": "^1.2.0",
    "jsonwebtoken": "9.0.2",
    "pg": "8.11.5"
  },
  "devDependencies": {
    "nodemon": "3.1.0"
  }
}
