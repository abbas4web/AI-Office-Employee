# Server
PORT=3000
NODE_ENV=development
JWT_SECRET=your_super_secret_jwt_key_change_this_min_32_chars
GROQ_API_KEY=gsk_your_groq_api_key_here

# CORS — comma-separated list of allowed frontend origins (production)
# Leave empty to allow all origins (development only)
ALLOWED_ORIGINS=https://your-frontend.vercel.app,https://yourdomain.com

# PostgreSQL - Option 1: Connection URL (Neon, Render, Heroku, etc.)
# DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# PostgreSQL - Option 2: Individual credentials (local development)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mydb
DB_USER=postgres
DB_PASSWORD=yourpassword
